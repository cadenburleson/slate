# Cloudflare Pages response headers.
# Copied from dist/_headers after `expo export -p web`.

/*
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin

# Static immutable assets (hashed filenames) — long cache.
/_expo/*
  Cache-Control: public, max-age=31536000, immutable

# Non-hashed user files in /assets/ (favicon, PWA icons, hero logo) share
# stable URLs across deploys, so they MUST be revalidate-able. Specific
# rules win over the broader /assets/* rule below per Cloudflare Pages
# header precedence.
/assets/favicon.svg
  Cache-Control: public, max-age=86400, must-revalidate
/assets/favicon.png
  Cache-Control: public, max-age=86400, must-revalidate
/assets/apple-touch-icon.png
  Cache-Control: public, max-age=86400, must-revalidate
/assets/icon-192.png
  Cache-Control: public, max-age=86400, must-revalidate
/assets/icon-512.png
  Cache-Control: public, max-age=86400, must-revalidate
/assets/logo.svg
  Cache-Control: public, max-age=86400, must-revalidate

# Hashed Expo asset paths (e.g. /assets/assets/logo.<hash>.png,
# /assets/node_modules/...) — these include a content hash in the URL,
# so immutable is correct: the URL itself changes when content changes.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Top-level metadata files — change rarely, set 30-day cache so Lighthouse's
# "uses-long-cache-ttl" audit passes. Updates still propagate via ETag.
/manifest.json
  Cache-Control: public, max-age=2592000, must-revalidate
/robots.txt
  Cache-Control: public, max-age=2592000, must-revalidate
/sitemap.xml
  Cache-Control: public, max-age=2592000, must-revalidate

# Slate snippet — embedded by third-party sites, served cross-origin.
# Short cache so newly-published page slugs propagate quickly to host sites.
/s.js
  Content-Type: application/javascript; charset=utf-8
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=300
